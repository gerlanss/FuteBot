# ----------------------------------------------------------------------
# Variaveis de ambiente do FuteBot
# Copie para .env e preencha seus valores
# ----------------------------------------------------------------------

# API-Football (Pro: 7.500 req/dia)
API_FOOTBALL_KEY=SUA_CHAVE_AQUI
DEFAULT_SEASON=2025

# The Odds API (Starter: 500 creditos/mes)
ODDS_API_KEY=SUA_CHAVE_AQUI

# Gemini (contexto externo: clima, noticias, etc.)
GEMINI_API_KEY=SUA_CHAVE_AQUI
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
USE_GEMINI_MARKET_LOOKUP=True

# Telegram Bot
TELEGRAM_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID
ADMIN_CHAT_IDS=SEU_CHAT_ID

# Fuso horario local
TIMEZONE=America/Boa_Vista
