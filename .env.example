# ----------------------------------------------------------------------
# Variaveis de ambiente do FuteBot
# Copie para .env e preencha seus valores
# ----------------------------------------------------------------------

# API-Football (Pro: 7.500 req/dia)
API_FOOTBALL_KEY=SUA_CHAVE_AQUI
DEFAULT_SEASON=2025

# The Odds API (Starter: 500 creditos/mes)
ODDS_API_KEY=SUA_CHAVE_AQUI

# OddsPapi v4 / 1xBet (funil final pre-live/live)
ODDSPAPI_KEY=SUA_CHAVE_AQUI
ODDSPAPI_BASE=https://api.oddspapi.io/v4
ODDSPAPI_BOOKMAKER_SLUG=1xbet
ODDSPAPI_BOOKMAKER_LABEL=1xBet
ODDSPAPI_USE_PRELIVE=True
ODDSPAPI_USE_LIVE=True
MODEL_CONFIDENCE_MIN=0.60
COMBO_TIP_CONFIDENCE_MIN=0.60
ODDSPAPI_SIMPLE_MIN_ODD=1.40
ODDSPAPI_SIMPLE_MIN_EV_PERCENT=5.0
ODDSPAPI_SIMPLE_WATCH_MIN_EV_PERCENT=2.0
LIVE_PRICE_WATCH_WINDOW_MIN=15
LIVE_PRICE_WATCH_RECHECK_MIN=5
ODDSPAPI_COMBO_LEG_MIN_ODD=1.20
ODDSPAPI_COMBO_LEG_MIN_EV_PERCENT=3.0
ODDSPAPI_COMBO_MIN_ODD=1.80
ODDSPAPI_COMBO_MIN_EV_PERCENT=6.0

# Gemini (contexto externo: clima, noticias, etc.)
GEMINI_API_KEY=SUA_CHAVE_AQUI
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
USE_GEMINI_MARKET_LOOKUP=True

# Telegram Bot
TELEGRAM_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID
ADMIN_CHAT_IDS=SEU_CHAT_ID

# Fuso horario local
TIMEZONE=America/Boa_Vista
